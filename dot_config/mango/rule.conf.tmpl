{{ end -}}
monitorrule=model:MAG321UX OLED,width:3840,height:2160,scale:1.0,refresh:240,vrr:0,x:0
monitorrule=model:CX158,width:2880,height:1800,scale:1.25,refresh:100,vrr:0,x:3840
