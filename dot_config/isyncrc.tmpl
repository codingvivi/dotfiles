
# AOL ACCOUNT SETTINGS
IMAPAccount aol
Host imap.aol.com
User {{ .email }}
PassCmd "pass email/aol | grep '^app-tw-fw25:' | cut -d' ' -f2"
TLSType IMAPS
CertificateFile {{ if eq (dig "id" "" .chezmoi.osRelease) "opensuse-tumbleweed" "opensuse-leap" "opensuse" }}/etc/ssl/ca-bundle.pem{{ else if eq (dig "id" "" .chezmoi.osRelease) "fedora" "asahi-remix" }}/etc/pki/tls/certs/ca-bundle.crt{{ else }}/etc/ssl/certs/ca-certificates.crt{{ end }}
PipelineDepth 5

# REMOTE STORAGE (The AOL server)
IMAPStore aol-remote
Account aol

# LOCAL STORAGE (Your computer)
MaildirStore aol-local
SubFolders Verbatim
# The trailing slash is important!
Path ~/Mail/AOL/
Inbox ~/Mail/AOL/Inbox

# THE BRIDGE (Connects Remote to Local)
Channel aol-sync
Far :aol-remote:
Near :aol-local:
# This syncs everything (folders, deletions, etc.)
Patterns *
Create Both
Expunge Both
SyncState *
